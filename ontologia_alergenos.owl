<owl:Ontology rdf:about="http://www.ufsc.br/food"/>

<owl:ObjectProperty rdf:about="#eDerivadoDe">
  <rdfs:domain rdf:resource="#Alimento"/>
  <rdfs:range rdf:resource="#Alimento"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">é derivado de</rdfs:label>
</owl:ObjectProperty>

<owl:Class rdf:about="#Alimento">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alimento</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#Alergeno">
  <rdfs:subClassOf rdf:resource="#Alimento"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alérgeno</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#AlergenoPorDerivacao">
  <rdfs:subClassOf rdf:resource="#Alimento"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Alimento"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#eDerivadoDe"/>
          <owl:someValuesFrom rdf:resource="#Alergeno"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alérgeno por Derivação</rdfs:label>
</owl:Class>

